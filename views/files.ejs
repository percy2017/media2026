<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Medios - Media2026</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <!-- Custom CSS -->
    <link href="/css/files.css" rel="stylesheet">
    
</head>
<body>
    <!-- Loading Overlay -->
    <div class="upload-loading" id="uploadLoading">
        <div class="text-center">
            <div class="spinner-border text-light" role="status" style="width: 4rem; height: 4rem; border-width: 4px;">
                <span class="visually-hidden">Subiendo...</span>
            </div>
            <p class="text-white mt-4 fs-5">Subiendo archivos...</p>
        </div>
    </div>

    <div class="container-fluid p-0">
        <!-- Header - Compact -->
        <header class="files-header">
            <div class="container-fluid">
                <div class="d-flex justify-content-between align-items-center py-1">
                    <a class="navbar-brand text-white text-decoration-none d-flex align-items-center" href="/files">
                        <i class="bi bi-folder-fill me-2"></i>
                        <span class="fw-semibold">Media2026</span>
                    </a>
                    <div class="d-flex align-items-center gap-2">
                        <!-- Mostrar nombre de usuario -->
                        <span class="text-white me-2 d-none d-md-inline">
                            <i class="bi bi-person-circle me-1"></i><%= user.name || 'Usuario' %>
                            <% if (user.role === 'admin') { %>
                                <span class="badge bg-warning text-dark ms-1">Admin</span>
                            <% } %>
                        </span>
                        
                        <!-- Link a Mi Perfil -->
                        <a href="/profile" class="btn btn-outline-light btn-sm py-1 px-2">
                            <i class="bi bi-person me-1"></i><span class="d-none d-sm-inline">Mi Perfil</span>
                        </a>
                        
                        <!-- Link a gestión de usuarios (solo admin) -->
                        <% if (user.role === 'admin') { %>
                            <a href="/admin/users" class="btn btn-outline-light btn-sm py-1 px-2">
                                <i class="bi bi-people me-1"></i><span class="d-none d-sm-inline">Usuarios</span>
                            </a>
                        <% } %>
                        
                        <a href="/logout" class="btn btn-outline-light btn-sm py-1 px-2">
                            <i class="bi bi-box-arrow-right me-1"></i><span class="d-none d-sm-inline">Cerrar Sesión</span>
                        </a>
                    </div>
                </div>
            </div>
        </header>
        
        <!-- Main Content -->
        <div class="p-3">
            <!-- Upload Card -->
            <div class="upload-card mb-4">
                <div class="card-body card-body-custom">
                    <!-- Breadcrumb & Directory Info -->
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb mb-0">
                                <li class="breadcrumb-item">
                                    <a href="/files" title="Directorio base" class="text-decoration-none">
                                        <i class="bi bi-house-door"></i> Medios
                                    </a>
                                </li>
                                <% breadcrumb.forEach(function(part, index) { %>
                                    <% if (index === breadcrumb.length - 1) { %>
                                        <li class="breadcrumb-item active" aria-current="page"><%= part %></li>
                                    <% } else { %>
                                        <li class="breadcrumb-item">
                                            <a href="/files?folder=<%= breadcrumb.slice(0, index + 1).join('/') %>"><%= part %></a>
                                        </li>
                                    <% } %>
                                <% }); %>
                            </ol>
                        </nav>
                        <div class="folder-badge">
                            <i class="bi bi-folder2 me-1"></i>
                            <%= currentFolder ? currentFolder : 'Raíz' %>
                        </div>
                    </div>
                    
                    <form id="uploadForm" action="/upload<%= currentFolder ? '?folder=' + currentFolder : '' %>" method="POST" enctype="multipart/form-data">
                        <input type="hidden" name="folder" value="<%= currentFolder || '' %>">
                        <div class="drop-zone" id="dropZone">
                            <i class="bi bi-cloud-arrow-up"></i>
                            <h5 class="mt-3 mb-1">Arrastra archivos aquí</h5>
                            <p class="text-muted mb-0 small">o haz clic para seleccionar</p>
                            <input type="file" name="files" id="fileInput" class="file-input" multiple accept="image/*,video/*,audio/*,.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt">
                        
                            <!-- Progress Bar -->
                            <div class="progress mt-3" id="uploadProgress" style="display: none;">
                                <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 0%">0%</div>
                            </div>
                        </div>
                        
                        <!-- Preview de archivos seleccionados -->
                        <div class="upload-preview" id="uploadPreview"></div>
                    </form>
                </div>
            </div>
            
            <!-- Alerts -->
            <% if (uploadSuccess) { %>
                <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i><%= uploadSuccess %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>
            
            <% if (uploadError) { %>
                <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i><%= uploadError %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>
            
            <!-- Toolbar -->
            <div class="toolbar-card">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <!-- Search Box -->
                        <div class="search-box">
                            <i class="bi bi-search"></i>
                            <input type="text" class="form-control" placeholder="Buscar archivos..." id="searchInput">
                        </div>
                        
                        <!-- New Folder Button -->
                        <button class="btn btn-outline-secondary" onclick="showNewFolderModal()">
                            <i class="bi bi-folder-plus me-1"></i> Nueva carpeta
                        </button>
                    </div>
                    
                    <!-- View Toggle -->
                    <div class="view-toggle">
                        <button class="btn active" id="gridViewBtn" title="Cuadrícula">
                            <i class="bi bi-grid-3x3-gap-fill"></i>
                        </button>
                        <button class="btn" id="listViewBtn" title="Lista">
                            <i class="bi bi-list-ul"></i>
                        </button>
                    </div>
                </div>
            </div>
            
            <!-- New Folder Modal -->
            <div class="modal fade" id="newFolderModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-sm modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">
                                <i class="bi bi-folder-plus me-2 text-primary"></i>Nueva carpeta
                            </h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <label for="newFolderName" class="form-label small text-muted">Nombre de la carpeta</label>
                            <input type="text" class="form-control" id="newFolderName" placeholder="Mi carpeta" autofocus>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                            <button type="button" class="btn btn-primary" onclick="createFolder()">
                                <i class="bi bi-folder-check me-1"></i> Crear
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Files Container -->
            <div id="filesContainer" class="files-grid-view">
                <% if (files && files.length > 0) { %>
                    <% files.forEach(function(file, index) { %>
                        <!-- Grid View Item -->
                        <div class="file-item file-grid-item" 
                             data-name="<%= file.name %>" 
                             data-type="<%= file.type %>"
                             data-size="<%= file.size %>"
                             data-date="<%= file.date %>"
                             data-url="<%= file.url %>"
                             data-current-folder="<%= currentFolder %>"
                             style="animation-delay: <%= index * 0.03 %>s">
                            <div class="card file-card h-100 <%= file.type === 'folder' ? 'folder-card' : '' %> <%= file.type === 'video' ? 'video-card' : '' %> <%= file.type === 'audio' ? 'audio-card' : '' %>">
                                <% if (file.type === 'folder') { %>
                                    <div class="folder-icon-bg">
                                        <i class="bi bi-folder-fill"></i>
                                    </div>
                                <% } else if (file.type === 'image') { %>
                                    <img src="<%= file.url %>" class="file-img" alt="<%= file.name %>" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                    <div class="file-icon-bg" style="display:none;">
                                        <i class="bi bi-image"></i>
                                    </div>
                                <% } else if (file.type === 'video') { %>
                                    <div class="file-icon-bg">
                                        <i class="bi bi-play-circle"></i>
                                    </div>
                                <% } else if (file.type === 'audio') { %>
                                    <div class="file-icon-bg">
                                        <i class="bi bi-soundwave"></i>
                                    </div>
                                <% } else { %>
                                    <div class="file-icon-bg">
                                        <i class="bi bi-file-earmark"></i>
                                    </div>
                                <% } %>
                                <div class="card-body">
                                    <h6 class="text-truncate mb-1" title="<%= file.name %>"><%= file.name %></h6>
                                    <p class="text-muted mb-0 small">
                                        <%= file.type === 'folder' ? 'Carpeta' : file.size %>
                                    </p>
                                    <div class="file-grid-actions mt-2">
                                        <% if (file.type === 'folder') { %>
                                            <button class="btn btn-sm btn-outline-primary" title="Abrir" onclick="event.stopPropagation(); window.location.href='/files?folder=<%= currentFolder ? encodeURIComponent(currentFolder + '/' + file.name) : encodeURIComponent(file.name) %>'">
                                                <i class="bi bi-folder2-open"></i>
                                            </button>
                                        <% } else { %>
                                            <a href="<%= file.url %>" download="<%= file.name %>" class="btn btn-sm btn-outline-primary" title="Descargar" onclick="event.stopPropagation()">
                                                <i class="bi bi-download"></i>
                                            </a>
                                        <% } %>
                                        <button class="btn btn-sm btn-outline-danger" onclick="event.stopPropagation(); deleteFile('<%= file.type %>', '<%= file.name %>')" title="Eliminar">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- List View Row -->
                        <div class="file-item file-list-row <%= file.type === 'folder' ? 'folder-row' : '' %>"
                             data-name="<%= file.name %>"
                             data-type="<%= file.type %>"
                             data-size="<%= file.size %>"
                             data-date="<%= file.date %>"
                             data-url="<%= file.url %>"
                             data-current-folder="<%= currentFolder %>">
                            <% if (file.type === 'folder') { %>
                                <div class="file-icon-cell">
                                    <i class="bi bi-folder-fill"></i>
                                </div>
                            <% } else if (file.type === 'image') { %>
                                <img src="<%= file.url %>" class="file-thumb" alt="<%= file.name %>">
                            <% } else if (file.type === 'video') { %>
                                <div class="file-icon-cell">
                                    <i class="bi bi-play-circle text-danger"></i>
                                </div>
                            <% } else if (file.type === 'audio') { %>
                                <div class="file-icon-cell">
                                    <i class="bi bi-soundwave text-success"></i>
                                </div>
                            <% } else { %>
                                <div class="file-icon-cell">
                                    <i class="bi bi-file-earmark"></i>
                                </div>
                            <% } %>
                            <div class="file-name"><%= file.name %></div>
                            <div class="file-date"><%= file.date %></div>
                            <div class="file-size"><%= file.type === 'folder' ? '-' : file.size %></div>
                            <div class="file-actions">
                                <% if (file.type === 'folder') { %>
                                    <button class="btn btn-sm btn-outline-primary" title="Abrir" onclick="window.location.href='/files?folder=<%= currentFolder ? encodeURIComponent(currentFolder + '/' + file.name) : encodeURIComponent(file.name) %>'">
                                        <i class="bi bi-folder2-open"></i>
                                    </button>
                                <% } else { %>
                                    <a href="<%= file.url %>" download="<%= file.name %>" class="btn btn-sm btn-outline-primary" title="Descargar">
                                        <i class="bi bi-download"></i>
                                    </a>
                                <% } %>
                                <button class="btn btn-sm btn-outline-danger" onclick="event.stopPropagation(); deleteFile('<%= file.type %>', '<%= file.name %>')" title="Eliminar">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="files-empty col-12">
                        <i class="bi bi-folder-x"></i>
                        <h4>No hay archivos</h4>
                        <p>Arrastra archivos aquí o haz clic en la zona de arriba para subir</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
    
    <!-- Preview Modal (Lightbox) -->
    <div class="preview-modal" id="previewModal">
        <button class="preview-close" onclick="closePreviewModal()" title="Cerrar (Esc)">
            <i class="bi bi-x-lg"></i>
        </button>
        <button class="preview-nav prev" onclick="navigatePreview(-1)" title="Anterior (←)">
            <i class="bi bi-chevron-left"></i>
        </button>
        <div class="preview-content" id="previewContent"></div>
        <button class="preview-nav next" onclick="navigatePreview(1)" title="Siguiente (→)">
            <i class="bi bi-chevron-right"></i>
        </button>
        <div class="preview-info" id="previewInfo"></div>
    </div>

    <!-- Right Sidebar - Attachment Details -->
    <div class="attachment-details" id="attachmentDetails">
        <button class="attachment-details-close" onclick="closeAttachmentDetails()" title="Cerrar (Esc)">
            <i class="bi bi-x-lg"></i>
        </button>
        <div class="attachment-preview" id="attachmentPreview">
            <i class="bi bi-file-earmark-fill" style="font-size: 5rem; color: #8a8a8a;"></i>
        </div>
        <div class="attachment-info">
            <h5>Detalles del archivo</h5>
            <div class="info-row">
                <span class="info-label">Nombre</span>
                <span class="info-value" id="detailName">-</span>
            </div>
            <div class="info-row">
                <span class="info-label">Tipo</span>
                <span class="info-value" id="detailType">-</span>
            </div>
            <div class="info-row">
                <span class="info-label">Tamaño</span>
                <span class="info-value" id="detailSize">-</span>
            </div>
            <div class="info-row">
                <span class="info-label">Fecha</span>
                <span class="info-value" id="detailDate">-</span>
            </div>
            <div class="info-row">
                <span class="info-label">URL</span>
                <span class="info-value">
                    <a href="#" id="detailUrl">Copiar enlace</a>
                </span>
            </div>
            <div class="attachment-actions" id="textActions" style="display: none;">
                <a href="#" id="detailEdit" class="btn btn-success">
                    <i class="bi bi-code-square me-2"></i> Editar
                </a>
            </div>
            <div class="attachment-actions">
                <a href="#" id="detailDownload" class="btn btn-primary">
                    <i class="bi bi-download me-2"></i> Descargar
                </a>
                <button class="btn btn-danger" id="detailDelete">
                    <i class="bi bi-trash me-2"></i> Eliminar
                </button>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- Custom JS -->
    <script src="/js/files.js"></script>
</body>
</html>
